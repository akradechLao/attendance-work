generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GroupType {
  A
  B
}

enum AttendanceStatus {
  late
  on_time
}

enum ShiftType {
  normal
  ot
  saturday
  sunday
  wfh
  holiday
}

model Employee {
  id                Int       @id @default(autoincrement())
  name              String
  groupType         GroupType @map("group_type")
  wfhQuota          Int       @default(1) @map("wfh_quota")
  preferredOffDay   String?   @map("preferred_off_day")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  attendanceLogs    AttendanceLog[]
  shiftSchedules    ShiftSchedule[]
  leaveRequests     LeaveRequest[]
  wfhRecords        WfhRecord[]
  onboarding        OnboardingRecord?

  @@map("employees")
}

model AttendanceLog {
  id            Int               @id @default(autoincrement())
  empId         Int               @map("emp_id")
  checkIn       String?           @map("check_in")
  checkInPhoto  String?           @db.Text @map("check_in_photo")
  checkOut      String?           @map("check_out")
  checkOutPhoto String?           @db.Text @map("check_out_photo")
  status        AttendanceStatus?
  latLong       String?           @map("lat_long")
  date          String
  createdAt     DateTime          @default(now()) @map("created_at")

  employee Employee @relation(fields: [empId], references: [id])

  @@unique([empId, date])
  @@map("attendance_logs")
}

model ShiftSchedule {
  id        Int      @id @default(autoincrement())
  empId     Int      @map("emp_id")
  workDate  String   @map("work_date")
  shiftType ShiftType @default(normal) @map("shift_type")
  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [empId], references: [id])

  @@unique([empId, workDate])
  @@map("shift_schedules")
}

model LeaveRequest {
  id        Int      @id @default(autoincrement())
  empId     Int      @map("emp_id")
  leaveType String   @map("leave_type")
  startDate String   @map("start_date")
  endDate   String   @map("end_date")
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [empId], references: [id])

  @@map("leave_requests")
}

model WfhRecord {
  id        Int      @id @default(autoincrement())
  empId     Int      @map("emp_id")
  date      String
  reason    String   @default("")
  status    String   @default("approved") // approved | pending | rejected
  createdAt DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [empId], references: [id])

  @@unique([empId, date])
  @@map("wfh_records")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model OfficeLocation {
  id          Int      @id @default(autoincrement())
  name        String
  latitude    Float
  longitude   Float
  radiusMeters Int     @default(200) @map("radius_meters")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("office_locations")
}

model CompanyHoliday {
  id        Int      @id @default(autoincrement())
  date      String
  name      String
  year      Int
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@map("company_holidays")
}

enum OnboardingStatus {
  in_progress
  completed
  on_hold
}

enum OnboardingDocStatus {
  pending
  submitted
  verified
  rejected
}

model OnboardingRecord {
  id          Int              @id @default(autoincrement())
  empId       Int              @unique @map("emp_id")
  status      OnboardingStatus @default(in_progress)
  startDate   String           @map("start_date")
  endDate     String?          @map("end_date")
  notes       String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  employee    Employee         @relation(fields: [empId], references: [id])
  steps       OnboardingStep[]
  documents   OnboardingDocument[]
  equipment   OnboardingEquipment[]
  training    OnboardingTraining[]

  @@map("onboarding_records")
}

model OnboardingStep {
  id              Int              @id @default(autoincrement())
  onboardingId    Int              @map("onboarding_id")
  stepOrder       Int              @map("step_order")
  stepKey         String           @map("step_key")
  stepLabel       String           @map("step_label")
  isCompleted     Boolean          @default(false) @map("is_completed")
  completedAt     DateTime?        @map("completed_at")
  completedBy     String?          @map("completed_by")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")

  onboarding      OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@unique([onboardingId, stepKey])
  @@map("onboarding_steps")
}

model OnboardingDocument {
  id              Int              @id @default(autoincrement())
  onboardingId    Int              @map("onboarding_id")
  docType         String           @map("doc_type")
  docLabel        String           @map("doc_label")
  status          OnboardingDocStatus @default(pending)
  fileUrl         String?          @db.Text @map("file_url")
  fileName        String?          @map("file_name")
  notes           String?
  verifiedAt      DateTime?        @map("verified_at")
  verifiedBy      String?          @map("verified_by")
  createdAt       DateTime         @default(now()) @map("created_at")

  onboarding      OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@map("onboarding_documents")
}

model OnboardingEquipment {
  id              Int              @id @default(autoincrement())
  onboardingId    Int              @map("onboarding_id")
  equipType       String           @map("equip_type")
  equipName       String           @map("equip_name")
  serialNumber    String?          @map("serial_number")
  notes           String?
  assignedAt      DateTime?        @map("assigned_at")
  returnedAt      DateTime?        @map("returned_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  onboarding      OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@map("onboarding_equipment")
}

model OnboardingTraining {
  id              Int              @id @default(autoincrement())
  onboardingId    Int              @map("onboarding_id")
  trainingName    String           @map("training_name")
  trainer         String?
  scheduledDate   String?          @map("scheduled_date")
  completedDate   String?          @map("completed_date")
  status          String           @default("scheduled") // scheduled | completed | cancelled
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")

  onboarding      OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@map("onboarding_training")
}
